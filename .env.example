# ─── App ───────────────────────────────────────────────────────────────
APP_NAME=1v1wager
ENVIRONMENT=development
DEBUG=true
API_BASE_URL=http://localhost:8000
# Browser app origin — OAuth callback redirects here with ?token=<jwt>
FRONTEND_URL=http://localhost:5173

# Demo mode: bypass real FACEIT/Payed so the app is clickable end-to-end.
# Set to false in production once real integrations are connected.
DEMO_MODE=true
DEMO_START_BALANCE=500.00

# ─── Security ──────────────────────────────────────────────────────────
# Used to sign session JWTs issued after FACEIT OAuth login
JWT_SECRET=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# ─── Database (PostgreSQL) ─────────────────────────────────────────────
# Must be an asyncpg DSN
DATABASE_URL=postgresql+asyncpg://wager:wager@localhost:5432/onev1wager
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# ─── Redis ─────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
# Set false to run without Redis (demo/local). Not for production.
REDIS_ENABLED=true

# ─── FACEIT ────────────────────────────────────────────────────────────
FACEIT_CLIENT_ID=your-faceit-oauth-client-id
FACEIT_CLIENT_SECRET=your-faceit-oauth-client-secret
FACEIT_REDIRECT_URI=http://localhost:8000/auth/faceit/callback
# Server-side API key (Data + Chat APIs)
FACEIT_API_KEY=your-faceit-server-api-key
# Secret used to verify inbound webhook signatures from FACEIT
FACEIT_WEBHOOK_SECRET=your-faceit-webhook-secret
FACEIT_OAUTH_AUTHORIZE_URL=https://accounts.faceit.com
FACEIT_OAUTH_SCOPE=openid profile email
FACEIT_OAUTH_TOKEN_URL=https://api.faceit.com/auth/v1/oauth/token
FACEIT_OAUTH_USERINFO_URL=https://api.faceit.com/auth/v1/resources/userinfo
FACEIT_API_BASE=https://open.faceit.com/data/v4

# ─── Payed.co payment gateway ──────────────────────────────────────────
PAYED_API_KEY=your-payed-api-key
PAYED_API_SECRET=your-payed-api-secret
PAYED_API_BASE=https://api.payed.co/v1
PAYED_WEBHOOK_SECRET=your-payed-webhook-secret
DEPOSIT_RETURN_URL=https://1v1wager.com/wallet/deposit/complete
WITHDRAWAL_RETURN_URL=https://1v1wager.com/wallet/withdraw/complete

# ─── ipinfo.io (geo lookup) ────────────────────────────────────────────
IPINFO_TOKEN=your-ipinfo-token
IPINFO_BASE=https://ipinfo.io

# ─── IPQualityScore (VPN / proxy detection) ────────────────────────────
IPQS_API_KEY=your-ipqualityscore-api-key
IPQS_BASE=https://ipqualityscore.com/api/json/ip

# ─── Geofencing / compliance ───────────────────────────────────────────
# Comma-separated ISO-3166 alpha-2 country codes, or "US-WA" style region codes.
BLOCKED_REGIONS=US-WA,US-ID,US-NV,US-LA,AU,FR,NL
# Comma-separated IPs of the reverse proxy / load balancer in front of the app.
# Only requests whose immediate peer is listed here have their X-Forwarded-For
# trusted for geo lookup — otherwise the header is ignored (anti-spoofing).
# MUST be set to your edge/proxy IP in production (e.g. behind Railway), or the
# real client IP is never read and geofencing silently falls open.
TRUSTED_PROXIES=127.0.0.1,::1
# Toggle VPN/proxy blocking
BLOCK_VPN=true
# Fail-open (allow) or fail-closed (block) when geo providers are unreachable
GEO_FAIL_OPEN=false
# Paths exempt from geofencing (health checks, webhooks)
GEO_EXEMPT_PATHS=/health,/webhook/faceit,/webhook/payed,/docs,/openapi.json

# ─── Economics ─────────────────────────────────────────────────────────
RAKE_PERCENT=10
MIN_WAGER=1.00
MAX_WAGER=1000.00
MIN_DEPOSIT=5.00
MIN_WITHDRAWAL=10.00

# Table formats: seats per side (1 => 1v1, 2 => 2v2, 5 => 5v5).
ALLOWED_TEAM_SIZES=1,2,5

# Economics: matches are 100% RTP (zero rake); the house is paid on withdrawal.
RAKE_PERCENT=0
WITHDRAWAL_FEE_PERCENT=20
# Deposits must be wagered through this many times before they can be withdrawn.
ROLLOVER_MULTIPLIER=1

# ─── SpinCounter (1v1 bracket tournaments) ─────────────────────────────
# Bracket sizes (players) — must be powers of two so the bracket has no byes.
# 2 is disabled by default (a lone 1v1 with no semifinal suspense = weak
# engagement); prepend "2," to re-enable head-to-head brackets.
SPIN_SIZES=4,8
SPIN_MIN_ENTRY=1.00
SPIN_MAX_ENTRY=500.00
# Rounds each 1v1 is played to (best-of); a player needs (n//2 + 1) round wins.
SPIN_ROUNDS_BEST_OF=3
# House rake on the tournament prize pool (separate from the jackpot rake below).
SPIN_RAKE_PERCENT=0
# Jackpot economics (self-funding — see docs/PLATFORM_ECONOMICS.md). A share of
# every entry pool funds the jackpot; the champion takes the rest. That budget
# is paid to one random entrant scaled by a multiplier drawn from
# SPIN_JACKPOT_MULTIPLIERS (mult:weight). Keep the multiplier's expected value
# ~1 so the jackpot is player-funded on average — a rare high multiplier still
# pays well over the buy-in without a runaway house cost.
SPIN_JACKPOT_RAKE_PERCENT=15
SPIN_JACKPOT_MULTIPLIERS=0:18,0.5:40,1:28,2:11,8:3
# Jackpot winnings raise the winner's rollover so it can't be cashed out without
# being wagered through first.
SPIN_WHEEL_ROLLOVER=true
